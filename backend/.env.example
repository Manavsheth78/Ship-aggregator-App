PORT=3001
DATABASE_URL=postgresql://postgres:root@localhost:5432/shipment_monitoring
JWT_SECRET=your-super-secret-jwt-key-change-in-production
NODE_ENV=development

# Email (Nodemailer - use Gmail, SendGrid, etc.)
